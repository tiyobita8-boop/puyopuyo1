<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>ぷよぷよミニ</title>
<style>
body {
  text-align:center;
  font-family:sans-serif;
}
canvas {
  background:#111;
  margin-top:20px;
}
</style>
</head>

<body>

<h1>ぷよぷよミニ</h1>
<p>← → 移動 / ↓ 落下 / ↑ 回転</p>

<canvas id="game" width="240" height="480"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

const COLS = 6;
const ROWS = 12;
const SIZE = 40;

let field = Array.from({length: ROWS}, () => Array(COLS).fill(0));

const colors = ["", "red", "blue", "green", "yellow"];

let puyo = {
  x: 2,
  y: 0,
  color: rand(),
  subColor: rand(),
  rot: 0
};

function rand(){
  return Math.floor(Math.random()*4)+1;
}

function draw(){
  ctx.clearRect(0,0,240,480);

  for(let y=0;y<ROWS;y++){
    for(let x=0;x<COLS;x++){
      if(field[y][x]){
        ctx.fillStyle = colors[field[y][x]];
        ctx.beginPath();
        ctx.arc(x*SIZE+20, y*SIZE+20, 18, 0, Math.PI*2);
        ctx.fill();
      }
    }
  }

  drawPuyo();
}

function drawPuyo(){
  drawOne(puyo.x, puyo.y, puyo.color);

  let dx = [0,1,0,-1][puyo.rot];
  let dy = [-1,0,1,0][puyo.rot];

  drawOne(puyo.x+dx, puyo.y+dy, puyo.subColor);
}

function drawOne(x,y,color){
  ctx.fillStyle = colors[color];
  ctx.beginPath();
  ctx.arc(x*SIZE+20, y*SIZE+20, 18, 0, Math.PI*2);
  ctx.fill();
}

function move(dx,dy){
  if(canMove(puyo.x+dx,puyo.y+dy,puyo.rot)){
    puyo.x += dx;
    puyo.y += dy;
  }
}

function rotate(){
  let newRot = (puyo.rot+1)%4;
  if(canMove(puyo.x,puyo.y,newRot)){
    puyo.rot = newRot;
  }
}

function canMove(x,y,rot){
  let dx = [0,1,0,-1][rot];
  let dy = [-1,0,1,0][rot];

  let positions = [
    [x,y],
    [x+dx,y+dy]
  ];

  return positions.every(([px,py])=>{
    return px>=0 && px<COLS && py<ROWS && (py<0 || field[py][px]==0);
  });
}

function fix(){
  let dx = [0,1,0,-1][puyo.rot];
  let dy = [-1,0,1,0][puyo.rot];

  field[puyo.y][puyo.x] = puyo.color;
  if(puyo.y+dy>=0)
    field[puyo.y+dy][puyo.x+dx] = puyo.subColor;

  clearPuyo();
  newPuyo();
}

function newPuyo(){
  puyo = {
    x: 2,
    y: 0,
    color: rand(),
    subColor: rand(),
    rot: 0
  };
}

function drop(){
  if(canMove(puyo.x,puyo.y+1,puyo.rot)){
    puyo.y++;
  } else {
    fix();
  }
}

function clearPuyo(){
  let visited = Array.from({length: ROWS},()=>Array(COLS).fill(false));
  let removed = false;

  for(let y=0;y<ROWS;y++){
    for(let x=0;x<COLS;x++){
      if(field[y][x] && !visited[y][x]){
        let group = [];
        dfs(x,y,field[y][x],group,visited);

        if(group.length >= 4){
          group.forEach(([gx,gy])=>{
            field[gy][gx]=0;
          });
          removed = true;
        }
      }
    }
  }

  if(removed){
    fall();
    setTimeout(clearPuyo,200);
  }
}

function dfs(x,y,color,group,visited){
  if(x<0||x>=COLS||y<0||y>=ROWS) return;
  if(visited[y][x]||field[y][x]!=color) return;

  visited[y][x]=true;
  group.push([x,y]);

  dfs(x+1,y,color,group,visited);
  dfs(x-1,y,color,group,visited);
  dfs(x,y+1,color,group,visited);
  dfs(x,y-1,color,group,visited);
}

function fall(){
  for(let x=0;x<COLS;x++){
    let stack=[];
    for(let y=ROWS-1;y>=0;y--){
      if(field[y][x]) stack.push(field[y][x]);
      field[y][x]=0;
    }
    for(let y=ROWS-1;y>=0;y--){
      if(stack.length) field[y][x]=stack.shift();
    }
  }
}

document.addEventListener("keydown",e=>{
  if(e.key==="ArrowLeft") move(-1,0);
  if(e.key==="ArrowRight") move(1,0);
  if(e.key==="ArrowDown") drop();
  if(e.key==="ArrowUp") rotate();
});

setInterval(()=>{
  drop();
  draw();
},500);

draw();
</script>

</body>
</html>
